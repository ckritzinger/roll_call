{
  "crons": [
    {
      "path": "/api/generate-week",
      "schedule": "0 4 * * 1"
    },
    {
      "path": "/api/powersync-keepalive",
      "schedule": "0 5 */3 * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    }
  ]
}
